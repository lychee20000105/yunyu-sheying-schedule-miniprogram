<view class="page">
	<view class="block">
		<view class="row">
			<text class="label">日期</text>
			<picker mode="date" value="{{rest.REST_DATE}}" bindchange="bindDateChange">
				<view>{{rest.REST_DATE}}</view>
			</picker>
		</view>
		<view class="row">
			<text class="label">类型</text>
			<picker range="{{types}}" bindchange="bindTypeChange">
				<view>{{rest.REST_TYPE}}</view>
			</picker>
		</view>
		<view class="area">
			<text class="label">原因</text>
			<textarea value="{{rest.REST_REASON}}" placeholder="填写休息、请假或调休原因" data-field="REST_REASON" bindinput="bindInput"></textarea>
		</view>
	</view>
	<button class="submit" bindtap="bindSubmitTap">提交审核</button>
</view>
