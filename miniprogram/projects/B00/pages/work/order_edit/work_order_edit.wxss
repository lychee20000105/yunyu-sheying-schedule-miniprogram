page {
	background: #f6f7f9;
}

.page {
	padding: 24rpx 24rpx 150rpx;
	box-sizing: border-box;
	width: 100%;
	max-width: 1120rpx;
	margin: 0 auto;
}

.block {
	background: #fff;
	border-radius: 12rpx;
	padding: 8rpx 26rpx;
	margin-bottom: 22rpx;
	box-sizing: border-box;
}

.row {
	min-height: 96rpx;
	display: flex;
	align-items: center;
	justify-content: space-between;
	border-bottom: 1rpx solid #f0f2f5;
	gap: 20rpx;
	box-sizing: border-box;
}

.row:last-child {
	border-bottom: 0;
}

.label {
	font-size: 30rpx;
	font-weight: 700;
	color: #111827;
	width: 230rpx;
	flex-shrink: 0;
	line-height: 1.35;
}

.value,
.input {
	flex: 1;
	font-size: 30rpx;
	color: #111827;
	text-align: right;
	min-width: 0;
	max-width: 100%;
	box-sizing: border-box;
	word-break: break-all;
}

.input {
	height: 88rpx;
}

picker {
	flex: 1;
	min-width: 0;
}

.block-head {
	height: 92rpx;
	display: flex;
	align-items: center;
	justify-content: space-between;
	font-size: 32rpx;
	font-weight: 800;
}

.small-btn {
	height: 54rpx;
	line-height: 54rpx;
	border-radius: 27rpx;
	padding: 0 24rpx;
	background: #111827;
	color: #fff;
	font-size: 26rpx;
	min-width: 96rpx;
	text-align: center;
	box-sizing: border-box;
}

.part {
	border-top: 1rpx solid #f0f2f5;
	padding: 22rpx 0;
}

.part-line {
	display: flex;
	align-items: center;
	flex-wrap: wrap;
	gap: 16rpx;
	margin-bottom: 16rpx;
}

.part-line picker {
	flex: 1;
	min-width: 210rpx;
}

.part-value,
.part-input,
.part-hint {
	min-width: 160rpx;
	width: 100%;
	height: 62rpx;
	line-height: 62rpx;
	border-radius: 10rpx;
	background: #f3f5f8;
	padding: 0 18rpx;
	font-size: 26rpx;
	box-sizing: border-box;
	overflow: hidden;
	white-space: nowrap;
	text-overflow: ellipsis;
}

.part-input {
	width: 220rpx;
	flex: 0 0 220rpx;
	text-align: right;
}

.part-hint {
	color: #8b9099;
}

.part-amount {
	color: #ff2d62;
	font-size: 26rpx;
}

.del {
	color: #dc2626;
	font-size: 26rpx;
	margin-left: auto;
	min-width: 92rpx;
	min-height: 62rpx;
	border-radius: 10rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	background: #fff1f2;
	box-sizing: border-box;
}

.muted {
	color: #8b9099;
	padding: 0 0 24rpx;
}

.imgs {
	display: flex;
	flex-wrap: wrap;
	gap: 18rpx;
	padding-bottom: 24rpx;
}

.img-wrap {
	position: relative;
	width: 150rpx;
	height: 150rpx;
	border-radius: 10rpx;
	overflow: hidden;
	background: #f3f5f8;
}

.img-wrap image {
	width: 100%;
	height: 100%;
}

.img-del {
	position: absolute;
	right: 8rpx;
	top: 8rpx;
	width: 46rpx;
	height: 46rpx;
	line-height: 42rpx;
	text-align: center;
	border-radius: 23rpx;
	background: rgba(0,0,0,.55);
	color: #fff;
	font-size: 34rpx;
}

.actions {
	position: fixed;
	left: 0;
	right: 0;
	bottom: 0;
	padding: 18rpx 24rpx calc(34rpx + env(safe-area-inset-bottom));
	background: rgba(246, 247, 249, .96);
	display: flex;
	gap: 14rpx;
	box-sizing: border-box;
}

.actions button {
	flex: 1;
	min-width: 0;
	height: 84rpx;
	line-height: 84rpx;
	border-radius: 42rpx;
	color: #fff;
	font-weight: 800;
	font-size: 28rpx;
	padding-left: 8rpx;
	padding-right: 8rpx;
	box-sizing: border-box;
}

.save {
	background: #111827;
}

.complete {
	background: #ff2d62;
}

.cancel {
	background: #9ca3af;
}
