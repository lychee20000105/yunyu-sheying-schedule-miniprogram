page {
	background: #f6f7f9;
}

.page {
	padding: 46rpx 28rpx;
}

.grid {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 24rpx;
}

.card {
	background: #fff;
	border-radius: 12rpx;
	padding: 34rpx 28rpx;
	min-height: 210rpx;
	box-shadow: 0 8rpx 26rpx rgba(15, 23, 42, .05);
}

.icon {
	width: 86rpx;
	height: 86rpx;
	line-height: 86rpx;
	border-radius: 18rpx;
	text-align: center;
	color: #fff;
	font-size: 40rpx;
	font-weight: 900;
	margin-bottom: 24rpx;
}

.blue { background: #1683ff; }
.yellow { background: #ffc400; }
.green { background: #16c784; }
.grey { background: #cfd3da; color: #6b7280; }

.title {
	font-size: 34rpx;
	font-weight: 900;
}

.desc {
	margin-top: 12rpx;
	color: #8b9099;
	font-size: 26rpx;
}
