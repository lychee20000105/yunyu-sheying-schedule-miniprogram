page { background: #f6f7f9; }
.page { padding: 24rpx; }
.month { height: 84rpx; line-height: 84rpx; background: #fff; border-radius: 12rpx; text-align: center; font-size: 36rpx; font-weight: 900; margin-bottom: 22rpx; }
.summary { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14rpx; margin-bottom: 26rpx; }
.summary view { background: #fff; border-radius: 12rpx; padding: 22rpx 12rpx; text-align: center; }
.summary text { color: #8b9099; font-size: 22rpx; }
.summary view view { padding: 10rpx 0 0; font-size: 34rpx; font-weight: 900; color: #111827; }
.section { font-size: 34rpx; font-weight: 900; margin: 30rpx 0 16rpx; }
.empty { color: #8b9099; padding: 24rpx; text-align: center; }
.card { position: relative; background: #fff; border-radius: 12rpx; padding: 26rpx; margin-bottom: 18rpx; }
.title { font-size: 30rpx; font-weight: 900; padding-right: 150rpx; }
.meta { color: #8b9099; margin-top: 12rpx; font-size: 24rpx; }
.amount { position: absolute; right: 26rpx; top: 30rpx; color: #ff2d62; font-size: 34rpx; font-weight: 900; }
.amount.muted { color: #6b7280; }
