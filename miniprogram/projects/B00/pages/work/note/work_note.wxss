page { background: #f6f7f9; }
.page { padding: 24rpx 24rpx 140rpx; }
.seg { display: flex; background: #eceff3; border-radius: 12rpx; padding: 6rpx; margin-bottom: 24rpx; }
.seg view { flex: 1; height: 64rpx; line-height: 64rpx; text-align: center; font-weight: 800; border-radius: 10rpx; color: #4b5563; }
.seg .active { background: #ff2d62; color: #fff; }
.card { background: #fff; border-radius: 12rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 8rpx 26rpx rgba(15,23,42,.05); }
.head { display: flex; align-items: center; justify-content: space-between; }
.title { font-size: 34rpx; font-weight: 900; }
.tag { background: #111827; color: #fff; border-radius: 8rpx; padding: 8rpx 16rpx; font-size: 24rpx; }
.content { margin-top: 20rpx; color: #374151; font-size: 28rpx; line-height: 1.6; max-height: 136rpx; overflow: hidden; }
.meta { margin-top: 20rpx; color: #8b9099; font-size: 24rpx; }
.empty { height: 300rpx; display: flex; align-items: center; justify-content: center; color: #8b9099; }
.fab { position: fixed; right: 42rpx; bottom: 130rpx; width: 104rpx; height: 104rpx; line-height: 96rpx; text-align: center; border-radius: 52rpx; background: #ff2d62; color: #fff; font-size: 70rpx; box-shadow: 0 14rpx 34rpx rgba(255,45,98,.32); }
