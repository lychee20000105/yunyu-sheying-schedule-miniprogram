page { background: #f6f7f9; }
.page { padding: 24rpx; }
.section { font-size: 34rpx; font-weight: 900; margin: 28rpx 0 16rpx; }
.empty { color: #8b9099; padding: 24rpx; text-align: center; }
.card { background: #fff; border-radius: 12rpx; padding: 26rpx; margin-bottom: 20rpx; }
.title { font-size: 32rpx; font-weight: 900; }
.meta { color: #8b9099; margin-top: 12rpx; }
.part { display: flex; align-items: center; justify-content: space-between; margin-top: 18rpx; background: #f6f7f9; border-radius: 8rpx; padding: 14rpx; }
.part input { width: 180rpx; text-align: right; color: #ff2d62; font-weight: 800; }
.actions { display: flex; gap: 14rpx; margin-top: 22rpx; }
.actions button { flex: 1; height: 76rpx; line-height: 76rpx; border-radius: 38rpx; color: #fff; font-weight: 800; }
.pass { background: #ff2d62; }
.reject { background: #9ca3af; }
