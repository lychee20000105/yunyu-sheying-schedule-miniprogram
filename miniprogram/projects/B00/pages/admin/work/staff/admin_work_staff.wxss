page { background: #f6f7f9; }
.page { padding: 24rpx; }
.block,.card { background: #fff; border-radius: 12rpx; padding: 26rpx; margin-bottom: 20rpx; }
.head { display: flex; justify-content: space-between; font-size: 34rpx; font-weight: 900; margin-bottom: 16rpx; }
.head view,.rule-head text { color: #ff2d62; font-size: 28rpx; }
.row { min-height: 88rpx; display: flex; align-items: center; justify-content: space-between; border-bottom: 1rpx solid #f0f2f5; }
.row text,.sub { font-weight: 800; }
.row input { text-align: right; }
.switches { display: flex; justify-content: space-between; padding: 20rpx 0; }
.chips { display: flex; flex-wrap: wrap; gap: 12rpx; padding: 18rpx 0; }
.chips view { background: #f3f5f8; border-radius: 8rpx; padding: 10rpx 18rpx; }
.chips .on { background: #111827; color: #fff; }
.rule-head { display: flex; justify-content: space-between; align-items: center; margin-top: 12rpx; }
.rule { display: grid; grid-template-columns: 1fr 1fr 110rpx 110rpx 50rpx; gap: 8rpx; align-items: center; margin-top: 14rpx; }
.rule view,.rule input { background: #f3f5f8; border-radius: 8rpx; padding: 12rpx; font-size: 24rpx; }
.rule text { color: #dc2626; text-align: center; }
.submit { margin-top: 26rpx; height: 84rpx; line-height: 84rpx; border-radius: 42rpx; background: #ff2d62; color: #fff; font-weight: 800; }
.name { font-size: 32rpx; font-weight: 900; }
.name text { background: #e5e7eb; color: #6b7280; font-size: 22rpx; padding: 4rpx 10rpx; border-radius: 6rpx; }
.meta { color: #8b9099; margin-top: 12rpx; }
