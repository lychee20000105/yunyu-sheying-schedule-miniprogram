
/* ==================
          按钮
 ==================== */

 .btn {
	border: 0rpx;
	display: inline-flex;
	align-items: center;
	justify-content: center;
	box-sizing: border-box;
	position: relative;
	padding: 0 30rpx;
	font-size: 28rpx;
	height: 64rpx;
	line-height: 1;
	text-align: center;
	text-decoration: none;
	overflow: visible;
	margin-left: initial;
	transform: translate(0rpx, 0rpx);
	margin-right: initial;
	border: 1rpx solid transparent;
	border-radius: 10rpx;
	font-weight: 500;
	box-shadow: 0 2rpx 6rpx rgba(15, 23, 42, 0.05);
	transition: opacity 0.16s ease, transform 0.16s ease, box-shadow 0.16s ease;
	-webkit-tap-highlight-color: transparent;
}

.btn::after {
	display: none;
}

.btn:not([class*="bg-"]) {
	background-color: #f6f7f9;
	color: #3b4252;
	border-color: rgba(15, 23, 42, 0.08);
	box-shadow: none;
}

.btn[class*="border"] {
	background-color: transparent;
	border-color: transparent;
	box-shadow: none;
}

/* 伪元素边框 */
.btn[class*="border"]::after {
	content: " ";
	display: block;
	width: 200%;
	height: 200%;
	position: absolute;
	top: 0;
	left: 0;
	border: 1rpx solid currentColor;
	transform: scale(0.5);
	transform-origin: 0 0;
	box-sizing: border-box;
	z-index: 1;
	pointer-events: none;
	border-radius: 10rpx;
} 

.btn[class*="bg-"]::after {
	display: none;
}

.btn[class*="bg-"] {
	box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.08);
}

.btn[class*="bg-"].light,
.btn.bg-gray,
.btn.bg-grey.light {
	border-color: rgba(15, 23, 42, 0.08);
	box-shadow: none;
}

.btn.bg-gray,
.btn.bg-grey.light {
	background-color: #f6f7f9 !important;
	color: #5b6472 !important;
}

.btn.bg-red,
.btn.bg-orange,
.btn.btn-danger,
.btn.btn-warn {
	box-shadow: 0 4rpx 12rpx rgba(229, 77, 66, 0.12);
}

.btn.bg-red.light,
.btn.bg-orange.light {
	border-color: rgba(229, 77, 66, 0.16);
	box-shadow: none;
}

.btn-primary {
	background-color: var(--blue) !important;
	color: var(--white) !important;
}

.btn-secondary {
	background-color: #f6f7f9 !important;
	color: #5b6472 !important;
	border-color: rgba(15, 23, 42, 0.08);
	box-shadow: none;
}

.btn-danger {
	background-color: var(--red) !important;
	color: var(--white) !important;
}

.btn-warn {
	background-color: var(--orange) !important;
	color: var(--white) !important;
}

.btn.small {
	padding: 0 20rpx;
	font-size: 20rpx;
	height: 48rpx;
	border-radius: 8rpx;
}

.btn.mid {
	padding: 0 20rpx;
	font-size: 24rpx;
	height: 50rpx;
	border-radius: 8rpx;
}

.btn.large {
	padding: 0 40rpx;
	font-size: 32rpx;
	height: 80rpx;
	border-radius: 12rpx;
}

.btn.btn-icon.small {
	width: 48rpx;
	height: 48rpx;
}

.btn.btn-icon {
	width: 64rpx;
	height: 64rpx;
	border-radius: 500rpx;
	padding: 0;
}

button.btn-icon.large {
	width: 80rpx;
	height: 80rpx;
}

.btn.shadow-blur::before {
	top: 4rpx;
	left: 4rpx;
	filter: blur(4rpx);
	opacity: 0.18;
}

.btn.button-hover { 
	opacity: .88;
	transform: translateY(1rpx);
	top: 0;
	left: 0;
	box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.12) inset;
}

.btn[disabled],
.btn.disabled {
	opacity: 1;
	color: #a1aab8 !important;
	background-color: #eef0f4 !important;
	border-color: rgba(15, 23, 42, 0.06);
	box-shadow: none;
	text-shadow: none;
}

.btn[loading],
.btn.loading,
.btn.submitting {
	opacity: .78;
	box-shadow: none;
}

.btn[loading].button-hover,
.btn.loading.button-hover,
.btn.submitting.button-hover,
.btn[disabled].button-hover,
.btn.disabled.button-hover {
	transform: translate(0rpx, 0rpx);
	box-shadow: none;
}


.btn.round {
	border-radius: 5000rpx;
}

.btn.round[class*="border"]::after {
	border-radius: 1000rpx;
}

.btn.border-bold::after {
	border: 6rpx solid currentColor;
}

